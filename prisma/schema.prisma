// ARKA — Prisma schema (SQLite dev / Postgres-ready)
// Relations mirror the spec: 1:1 Project↔Seo, 1:N Client→Projects,
// M:N Projects↔Services and Projects↔Industries.
// JSON-shaped values are stored as String (JSON.stringify) for SQLite
// portability and parsed at the app boundary (see lib/utils parseArr/parseObj).

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Admin users with role-based + granular permission access control.
model User {
  id            String        @id @default(cuid())
  email         String        @unique
  password      String
  name          String
  avatar        String?
  role          String        @default("EDITOR") // SUPER_ADMIN | ADMIN | EDITOR | AUTHOR | VIEWER | STAFF
  permissions   String        @default("[]") // JSON string[] — granular overrides on top of role
  bio           String?
  active        Boolean       @default(true)
  lastLoginAt   DateTime?
  posts         Post[]
  tasksAssigned Task[]        @relation("TaskAssignee")
  tasksCreated  Task[]        @relation("TaskCreatedBy")
  taskComments  TaskComment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

/// Brands ARKA works with (1:N → projects, testimonials).
model Client {
  id           String        @id @default(cuid())
  name         String
  nameEn       String?
  logo         String?
  website      String?
  industry     String?
  featured     Boolean       @default(false)
  order        Int           @default(0)
  projects     Project[]
  testimonials Testimonial[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

/// Core service offerings, each with its own landing page.
model Service {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  titleEn         String?
  titleAr         String?
  tagline         String?
  excerpt         String
  description     String
  department      String    @default("FILM") // FILM | DIGITAL | DESIGN | STRATEGY
  icon            String    @default("Clapperboard")
  cover           String?
  heroVideo       String?
  priceFrom       Int?
  priceUnit       String?   @default("تومان")
  features        String    @default("[]") // JSON string[]
  workflow        String    @default("[]") // JSON [{step,title,desc}]
  faqs            String    @default("[]") // JSON [{q,a}]
  pricing         String    @default("[]") // JSON [{name,price,unit,features[],featured}]
  order           Int       @default(0)
  published       Boolean   @default(true)
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  keywords        String    @default("[]")
  projects        Project[] @relation("ProjectServices")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

/// Industry verticals, each a dedicated landing page with a hover hero video.
model Industry {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  titleEn         String?
  titleAr         String?
  excerpt         String
  description     String
  icon            String    @default("Building2")
  cover           String?
  heroVideo       String? // hover-to-play background video
  approach        String    @default("[]") // JSON string[]
  order           Int       @default(0)
  published       Boolean   @default(true)
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  keywords        String    @default("[]")
  projects        Project[] @relation("ProjectIndustries")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

/// Portfolio project / case study — the core content type.
model Project {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  titleEn     String?
  subtitle    String?
  clientId    String?
  client      Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  category    String     @default("Film")
  cover       String
  poster      String?
  heroVideo   String?
  gallery     String     @default("[]") // JSON string[]
  year        Int        @default(2025)
  location    String?
  accent      String     @default("#6699ff")
  featured    Boolean    @default(false)
  published   Boolean    @default(true)
  order       Int        @default(0)
  tags        String     @default("[]") // JSON string[]
  // storytelling framework: Goal → Problem → Idea → Production → Marketing → Result
  goal        String?
  problem     String?
  idea        String?
  production  String?
  marketing   String?
  result      String?
  metrics     String     @default("[]") // JSON [{label,value,suffix}]
  beforeImage String?
  afterImage  String?
  credits     String     @default("[]") // JSON [{role,name}]
  views       Int        @default(0)
  services    Service[]  @relation("ProjectServices")
  industries  Industry[] @relation("ProjectIndustries")
  seo         Seo? // 1:1
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  publishedAt DateTime   @default(now())
}

/// 1:1 SEO record attached to a project.
model Seo {
  id              String  @id @default(cuid())
  projectId       String  @unique
  project         Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  canonical       String?
  keywords        String  @default("[]")
  noindex         Boolean @default(false)
}

/// Blog / Journal editorial posts.
model Post {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  titleEn         String?
  excerpt         String
  cover           String
  content         String // markdown
  category        String   @default("Insights")
  tags            String   @default("[]")
  authorId        String?
  author          User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  readingMinutes  Int      @default(5)
  featured        Boolean  @default(false)
  published       Boolean  @default(true)
  views           Int      @default(0)
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  keywords        String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  publishedAt     DateTime @default(now())
}

/// Media library asset (S3/CDN URL in prod; sample CDN links in dev).
model Media {
  id        String   @id @default(cuid())
  url       String
  type      String   @default("IMAGE") // IMAGE | VIDEO | DOC
  name      String
  alt       String?
  folder    String   @default("uploads")
  width     Int?
  height    Int?
  size      Int? // bytes
  createdAt DateTime @default(now())
}

/// Client testimonials.
model Testimonial {
  id        String   @id @default(cuid())
  author    String
  role      String?
  company   String?
  avatar    String?
  quote     String
  rating    Int      @default(5)
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  featured  Boolean  @default(true)
  published Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

/// Inbound inquiries from the contact form → CRM pipeline.
model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  budget    String?
  service   String?
  plan      String? // pricing tier selected via a service page's "انتخاب پلن" button
  message   String
  status    String   @default("NEW") // NEW | CONTACTED | PROPOSAL | WON | LOST
  source    String   @default("website")
  createdAt DateTime @default(now())
}

/// Editable homepage statistic counters.
model Stat {
  id     String @id @default(cuid())
  label  String
  value  Int
  suffix String @default("+")
  order  Int    @default(0)
}

/// "The Minds Behind the Magic" team members.
model TeamMember {
  id        String  @id @default(cuid())
  name      String
  nameEn    String?
  role      String
  bio       String?
  avatar    String?
  socials   String  @default("[]") // JSON [{platform,href}]
  order     Int     @default(0)
  published Boolean @default(true)
}

/// Global key/value site settings (JSON values).
model Setting {
  key   String @id
  value String // JSON
}

/// Singleton content for the public homepage (one row, id fixed to "home").
model HomePage {
  id                          String   @id @default("home")
  heroBadge                   String   @default("استودیوی خلاقیت، پروداکشن و دیجیتال مارکتینگ")
  heroHeadline                String   @default("[]") // JSON string[3] — three stacked hero lines
  heroDescription              String   @default("آرکا یک پروداکشن‌هاوس خلاق است؛ برندها را با هنر بصری سینمایی، راهکارهای دیجیتال و روایت داده‌محور به سطحی تازه می‌رساند.")
  heroCtaLabel                 String   @default("شروع پروژه")
  heroReelLabel                String   @default("تماشای شوریل ۲۰۲۵")
  trustCaption                 String   @default("اعتماد بیش از ۱۲۰ برند پیشرو")
  departmentsEyebrow           String   @default("۴ دپارتمان تخصصی")
  departmentsHeading           String   @default("یک تیم، تمام تخصص‌ها")
  departmentsHeadingHighlight  String   @default("تمام تخصص‌ها")
  departmentsDescription       String   @default("از ایده تا اکران؛ همه‌ی آنچه برای ساختن یک برند متمایز لازم است، زیر یک سقف.")
  departmentsCtaLabel          String   @default("کشف خدمات")
  featuredEyebrow               String   @default("نمونه‌کارهای منتخب")
  featuredHeading                String   @default("کارهایی که حرف می‌زنند")
  featuredHeadingHighlight       String   @default("حرف می‌زنند")
  featuredDescription             String   @default("هر پروژه، یک داستان است: از چالش تا نتیجه‌ای قابل‌اندازه‌گیری.")
  featuredCtaLabel                String   @default("تمام پروژه‌ها")
  workflowEyebrow                  String   @default("فرایند کار")
  workflowHeading                   String   @default("مسیری شفاف تا تأثیر واقعی")
  workflowHeadingHighlight          String   @default("تأثیر واقعی")
  workflowDescription                String   @default("چهار گام روشن که خلاقیت را به نتیجه‌ی تجاری تبدیل می‌کند.")
  workflowSteps                      String   @default("[]") // JSON [{icon,title,desc}] — 4 steps
  testimonialsEyebrow                 String   @default("صدای مشتریان")
  testimonialsHeading                  String   @default("برندهایی که به ما اعتماد کردند")
  testimonialsHeadingHighlight         String   @default("به ما اعتماد کردند")
  finalEyebrow                         String   @default("آماده‌اید متمایز شوید؟")
  finalHeading                          String   @default("بیایید برندی بسازیم که فراموش نشود")
  finalHeadingHighlight                 String   @default("فراموش نشود")
  finalDescription                       String   @default("یک ایده کافی است. باقی مسیر را با هم می‌سازیم.")
  finalCtaLabel                          String   @default("شروع پروژه")
  updatedAt                              DateTime @updatedAt
}

/// Singleton content for the public /about page (one row, id fixed to "about").
model AboutPage {
  id                 String   @id @default("about")
  heroEyebrow        String   @default("درباره آرکا")
  heroTitle          String   @default("ذهن‌های پشتِ جادو")
  heroTitleHighlight String   @default("جادو") // substring of heroTitle rendered in the gradient accent
  heroDescription    String   @default("ما فقط محتوا نمی‌سازیم؛ برای برندها روایت می‌سازیم، تجربه خلق می‌کنیم و تأثیر می‌گذاریم.")
  storyEyebrow       String   @default("داستان ما")
  storyHeading       String   @default("یک پروداکشن‌هاوس، نه صرفاً یک آژانس")
  storyParagraphs    String   @default("[]") // JSON string[]
  storyVideo         String?
  storyPoster        String?
  valuesEyebrow      String   @default("ارزش‌ها")
  valuesHeading      String   @default("آنچه ما را متمایز می‌کند")
  values             String   @default("[]") // JSON [{icon,title,desc}]
  teamEyebrow        String   @default("تیم")
  teamHeading        String   @default("ذهن‌های خلاق آرکا")
  timelineEyebrow    String   @default("مسیر رشد")
  timelineHeading    String   @default("سفر آرکا در یک نگاه")
  timeline           String   @default("[]") // JSON [{year,title,desc}]
  galleryEyebrow     String   @default("پشت صحنه")
  galleryHeading     String   @default("جادو چگونه ساخته می‌شود")
  galleryVideo       String?
  galleryPoster      String?
  galleryImages      String   @default("[]") // JSON string[]
  metaTitle          String?
  metaDescription    String?
  updatedAt          DateTime @updatedAt
}

/// Singleton content for the public /contact page (one row, id fixed to "contact").
model ContactPage {
  id              String   @id @default("contact")
  heroEyebrow     String   @default("تماس")
  heroTitle       String   @default("بیایید شروع کنیم")
  heroTitleHighlight String @default("شروع کنیم") // substring of heroTitle rendered in the gradient accent
  heroDescription String   @default("ایده‌ای در سر دارید؟ فرم را پر کنید یا مستقیم با ما در ارتباط باشید.")
  address         String   @default("تهران، خیابان ولیعصر، برج آرکا، طبقه ۱۲")
  phone           String   @default("+982188000000")
  phoneDisplay    String   @default("۰۲۱ ۸۸۰۰ ۰۰۰۰")
  email           String   @default("hello@arka.studio")
  officeHours     String   @default("شنبه تا چهارشنبه، ۹ تا ۱۸")
  mapLat          Float    @default(35.7448)
  mapLng          Float    @default(51.4101)
  socials         String   @default("[]") // JSON [{platform,href,label}]
  serviceOptions  String   @default("[]") // JSON string[] — contact form "service" dropdown
  budgetOptions   String   @default("[]") // JSON string[] — contact form "budget" dropdown
  metaTitle       String?
  metaDescription String?
  updatedAt       DateTime @updatedAt
}

/// Internal task assigned by an admin to a staff/team member (viewed in /portal).
model Task {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      String        @default("TODO") // TODO | IN_PROGRESS | DONE | CANCELLED
  priority    String        @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  dueDate     DateTime?
  assigneeId  String
  assignee    User          @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?         @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  comments    TaskComment[]
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

/// Status/note thread on a Task — addable by the assignee (/portal) and by admins with tasks.manage.
model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  body      String
  createdAt DateTime @default(now())
}

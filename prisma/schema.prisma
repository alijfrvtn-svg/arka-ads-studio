/// Singleton content for the public /about page (one row, id fixed to "about").
model AboutPage {
  id                   String   @id @default("about")
  heroEyebrow          String   @default("ШҜШұШЁШ§ШұЩҮ ШўШұЪ©Ш§")
  heroEyebrowEn        String?
  heroEyebrowAr        String?
  heroTitle            String   @default("Ш°ЩҮЩҶвҖҢЩҮШ§ЫҢ ЩҫШҙШӘЩҗ Ш¬Ш§ШҜЩҲ")
  heroTitleEn          String?
  heroTitleAr          String?
  heroTitleHighlight   String   @default("Ш¬Ш§ШҜЩҲ") // substring of heroTitle rendered in the gradient accent
  heroTitleHighlightEn String? // substring of heroTitleEn
  heroTitleHighlightAr String? // substring of heroTitleAr
  heroDescription      String   @default("Щ…Ш§ ЩҒЩӮШ· Щ…ШӯШӘЩҲШ§ ЩҶЩ…ЫҢвҖҢШіШ§ШІЫҢЩ…Шӣ ШЁШұШ§ЫҢ ШЁШұЩҶШҜЩҮШ§ ШұЩҲШ§ЫҢШӘ Щ…ЫҢвҖҢШіШ§ШІЫҢЩ…ШҢ ШӘШ¬ШұШЁЩҮ Ш®Щ„ЩӮ Щ…ЫҢвҖҢЪ©ЩҶЫҢЩ… ЩҲ ШӘШЈШ«ЫҢШұ Щ…ЫҢвҖҢЪҜШ°Ш§ШұЫҢЩ….")

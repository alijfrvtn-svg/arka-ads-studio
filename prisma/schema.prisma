/// Internal task assigned by an admin to a staff/team member (viewed in /portal).
model Task {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      String        @default("TODO") // TODO | IN_PROGRESS | DONE | CANCELLED
  priority    String        @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  dueDate     DateTime?
  assigneeId  String
  assignee    User          @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  createdById String?
  createdBy   User?         @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  comments    TaskComment[]
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

/// Status/note thread on a Task вҖ” addable by the assignee (/portal) and by admins with tasks.manage.
model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  body      String
  createdAt DateTime @default(now())
}
